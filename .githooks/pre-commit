#!/usr/bin/env bash
# pre-commit hook：提交前强制执行 ruff 检查与单元测试
#
# 安装方式（任选其一）：
#   1. git config core.hooksPath .githooks
#   2. bash .githooks/install.sh
#   3. .githooks\install.bat  (Windows)
#
# 跳过方式（仅紧急情况，请在 commit message 注明原因）：
#   git commit --no-verify

set -euo pipefail

# 切换到仓库根目录
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ===== 环境探测 =====
# 优先使用 uv（与 CI 一致），找不到则回退到 .venv，再回退到系统 python
if command -v uv >/dev/null 2>&1; then
    PY_RUN="uv run"
elif [ -f ".venv/Scripts/python.exe" ]; then
    PY_RUN=".venv/Scripts/python.exe -m"
elif [ -f ".venv/bin/python" ]; then
    PY_RUN=".venv/bin/python -m"
else
    PY_RUN="python -m"
fi

echo "==> [pre-commit] 使用执行器: $PY_RUN"

# ===== 1. 保护 config.ini 不被测试污染 =====
# 测试运行可能通过 config_manager 单例写入工作区的 config.ini，导致工作树脏。
# 这里在测试前快照工作区 config.ini 内容，测试后比对，若被修改则恢复。
CONFIG_SNAPSHOT=""
if [ -f "$REPO_ROOT/config.ini" ]; then
    CONFIG_SNAPSHOT="$(git rev-parse --git-dir)/pre-commit-config-snapshot"
    cp -f "$REPO_ROOT/config.ini" "$CONFIG_SNAPSHOT" 2>/dev/null || true
fi

# 退出时（无论成功/失败/中断）恢复 config.ini 并清理快照
restore_config() {
    if [ -n "${CONFIG_SNAPSHOT:-}" ] && [ -f "$CONFIG_SNAPSHOT" ]; then
        if ! diff -q "$REPO_ROOT/config.ini" "$CONFIG_SNAPSHOT" >/dev/null 2>&1; then
            cp -f "$CONFIG_SNAPSHOT" "$REPO_ROOT/config.ini"
            echo "⚠️  检测到 config.ini 被测试运行污染，已自动恢复到提交前状态"
        fi
        rm -f "$CONFIG_SNAPSHOT"
    fi
}
trap restore_config EXIT

# ===== 2. Ruff 静态检查（仅检查暂存文件以加速）=====
STAGED_PY_FILES="$(git diff --cached --name-only --diff-filter=ACM -- '*.py')"
if [ -n "$STAGED_PY_FILES" ]; then
    echo "==> [pre-commit] ruff check（仅暂存的 .py 文件）"
    # shellcheck disable=SC2086
    $PY_RUN ruff check $STAGED_PY_FILES || {
        echo "❌ ruff check 失败，请修复后再提交（或使用 git commit --no-verify 跳过）"
        exit 1
    }
    echo "==> [pre-commit] ruff format --check（仅暂存的 .py 文件）"
    # shellcheck disable=SC2086
    $PY_RUN ruff format --check $STAGED_PY_FILES || {
        echo "❌ ruff format 检查失败，请执行 ruff format 后再提交"
        exit 1
    }
else
    echo "==> [pre-commit] 无 .py 文件改动，跳过 ruff"
fi

# ===== 3. 单元测试 =====
# 默认全量测试；如需加速可通过 PRECOMMIT_TEST_ARGS 环境变量传入额外参数
# 例如：PRECOMMIT_TEST_ARGS="-x tests/services" git commit
TEST_ARGS="${PRECOMMIT_TEST_ARGS:-}"
echo "==> [pre-commit] 运行单元测试（参数: $TEST_ARGS）"
# -p no:cacheprovider 避免缓存干扰；--tb=short 精简失败输出
if ! $PY_RUN pytest tests/ -p no:cacheprovider --tb=short -q $TEST_ARGS; then
    echo "❌ 单元测试失败，提交已阻止（或使用 git commit --no-verify 跳过）"
    exit 1
fi

echo "✅ pre-commit 检查全部通过"
exit 0
