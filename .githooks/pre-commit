#!/usr/bin/env bash
# pre-commit hook：提交前强制执行依赖同步、代码检查、模板格式化与单元测试
#
# 安装方式（任选其一）：
#   1. git config core.hooksPath .githooks
#   2. bash .githooks/install.sh
#   3. .githooks\install.bat  (Windows)
#
# 跳过方式（仅紧急情况，请在 commit message 注明原因）：
#   git commit --no-verify

set -euo pipefail

# 切换到仓库根目录
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ===== 环境探测 =====
# 优先使用 uv（与 CI 一致），找不到则回退到 .venv
if command -v uv >/dev/null 2>&1; then
    PY_RUN="uv run"
    HAS_UV=true
elif [ -f ".venv/Scripts/python.exe" ]; then
    PY_RUN=".venv/Scripts/python.exe -m"
    HAS_UV=false
elif [ -f ".venv/bin/python" ]; then
    PY_RUN=".venv/bin/python -m"
    HAS_UV=false
else
    PY_RUN="python -m"
    HAS_UV=false
fi

echo "==> [pre-commit] 执行器: $PY_RUN"

# 记录格式化前的已暂存文件列表（用于格式化后自动重新暂存）
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

# ===== 1. 依赖锁文件同步（仅当 pyproject.toml 在暂存区时） =====
if echo "$STAGED_FILES" | grep -q '^pyproject\.toml$'; then
    if [ "$HAS_UV" = true ]; then
        echo "==> [1/7] uv lock（pyproject.toml 已修改）"
        uv lock || { echo "❌ uv lock 失败"; exit 1; }
        echo "    uv export requirements.txt"
        uv export --format requirements.txt --no-dev -o requirements.txt || {
            echo "❌ uv export 失败"; exit 1; }
        git add uv.lock requirements.txt
        echo "    已重新暂存 uv.lock + requirements.txt"
    else
        echo "==> [1/7] 跳过 uv lock（未检测到 uv）"
    fi
else
    echo "==> [1/7] 跳过 uv lock（pyproject.toml 未修改）"
fi

# ===== 2. Ruff 静态检查（全量） =====
echo "==> [2/7] ruff check ."
$PY_RUN ruff check . || {
    echo "❌ ruff check 失败，请修复后再提交（或使用 git commit --no-verify 跳过）"
    exit 1
}

# ===== 3. Ruff 格式化（全量，会修改文件） =====
echo "==> [3/7] ruff format ."
$PY_RUN ruff format . || {
    echo "❌ ruff format 失败"
    exit 1
}

# ===== 4. DjLint 模板格式化（templates/，会修改文件） =====
echo "==> [4/7] djlint templates/ --reformat"
$PY_RUN djlint templates/ --reformat || {
    echo "❌ djlint 失败"
    exit 1
}

# ===== 5. 自动重新暂存被格式化修改的文件 =====
echo "==> [5/7] 重新暂存格式化后的文件"
RE_STAGED=""
if ! git diff --quiet; then
    # 只重新暂存原本就在暂存区中的文件，避免误提交未暂存的改动
    while IFS= read -r f; do
        [ -n "$f" ] && [ -f "$f" ] && git add "$f" 2>/dev/null && RE_STAGED="$RE_STAGED $f"
    done <<< "$STAGED_FILES"
    if [ -n "$RE_STAGED" ]; then
        echo "    已自动重新暂存:$RE_STAGED"
    fi
fi

# ===== 6. 单元测试 + 覆盖率 =====
echo "==> [6/7] pytest tests/ --cov=app --cov-report=term"
if ! $PY_RUN pytest tests/ --cov=app --cov-report=term; then
    echo "❌ 单元测试失败，提交已阻止（或使用 git commit --no-verify 跳过）"
    exit 1
fi

echo "==> [7/7] 检查完成"
echo "✅ pre-commit 检查全部通过"
exit 0
